<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.AcademicHub" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/teal_400</item>
        <item name="colorPrimaryVariant">@color/navy_800</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/amber_400</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:colorBackground">@color/surface_light</item>
        <item name="colorSurface">@color/surface_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:statusBarColor">@color/navy_900</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="bottomSheetDialogTheme">@style/BottomSheetDialogTheme</item>
    </style>

    <style name="BottomSheetDialogTheme" parent="Theme.MaterialComponents.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/BottomSheetStyle</item>
    </style>

    <style name="BottomSheetStyle" parent="Widget.MaterialComponents.BottomSheet.Modal">
        <item name="shapeAppearanceOverlay">@style/BottomSheetRounded</item>
    </style>

    <style name="BottomSheetRounded">
        <item name="cornerSizeTopLeft">24dp</item>
        <item name="cornerSizeTopRight">24dp</item>
    </style>

</resources>
