<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/iv_cat_icon"
            android:layout_width="16dp"
            android:layout_height="16dp"
            tools:src="@drawable/ic_assignment_small"
            android:tint="@color/teal_400"
            android:contentDescription="category icon" />

        <TextView
            android:id="@+id/tv_cat_name"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            tools:text="Assignments"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="@color/text_primary"
            android:layout_marginStart="8dp" />

        <TextView
            android:id="@+id/tv_cat_weight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="30%"
            android:textSize="11sp"
            android:textColor="@color/text_hint"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/tv_cat_score"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="95%"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="@color/grade_a" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/pb_cat_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:max="100"
        android:progress="95"
        android:progressDrawable="@drawable/progress_teal"
        android:layout_marginTop="4dp"
        android:layout_marginStart="24dp" />

</LinearLayout>
