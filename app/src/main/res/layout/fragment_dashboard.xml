<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/surface_light">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@drawable/bg_header_gradient"
            android:paddingStart="24dp" android:paddingEnd="24dp"
            android:paddingTop="52dp" android:paddingBottom="32dp">

            <TextView android:id="@+id/tv_greeting" android:layout_width="0dp"
                android:layout_height="wrap_content" android:text="Hello, Noah 👋"
                android:textStyle="bold" android:textSize="24sp" android:textColor="@color/white"
                app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/iv_avatar" />

            <TextView android:id="@+id/tv_subtitle" android:layout_width="0dp"
                android:layout_height="wrap_content" android:text="Here's your academic snapshot"
                android:textSize="14sp" android:textColor="#B0C4D8" android:layout_marginTop="2dp"
                app:layout_constraintTop_toBottomOf="@id/tv_greeting"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/iv_avatar" />

            <ImageView android:id="@+id/iv_avatar" android:layout_width="44dp"
                android:layout_height="44dp" android:src="@drawable/ic_avatar_placeholder"
                android:background="@drawable/bg_avatar_circle" android:scaleType="center"
                android:padding="8dp" android:contentDescription="Profile"
                app:layout_constraintTop_toTopOf="parent" app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="@id/tv_subtitle" />

            <!-- GPA Card -->
            <androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/card_gpa_row"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:background="@drawable/bg_gpa_card" android:layout_marginTop="20dp"
                android:padding="16dp"
                app:layout_constraintTop_toBottomOf="@id/tv_subtitle"
                app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout android:id="@+id/block_current_gpa" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:orientation="vertical"
                    app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="GPA" android:textStyle="bold" android:textSize="11sp"
                        android:textColor="#80B0CC" android:letterSpacing="0.1" />
                    <TextView android:id="@+id/tv_gpa" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="3.74"
                        android:textStyle="bold" android:textSize="38sp" android:textColor="@color/teal_300" />
                </LinearLayout>

                <View android:id="@+id/gpa_divider" android:layout_width="1dp" android:layout_height="0dp"
                    android:background="#30FFFFFF" android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
                    app:layout_constraintStart_toEndOf="@id/block_current_gpa"
                    app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent" />

                <LinearLayout android:id="@+id/block_target_gpa" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:orientation="vertical"
                    app:layout_constraintStart_toEndOf="@id/gpa_divider"
                    app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="TARGET" android:textStyle="bold" android:textSize="11sp"
                        android:textColor="#80B0CC" android:letterSpacing="0.1" />
                    <TextView android:id="@+id/tv_target_gpa" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="3.80"
                        android:textStyle="bold" android:textSize="38sp" android:textColor="@color/amber_300" />
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:orientation="vertical" android:layout_marginStart="16dp"
                    app:layout_constraintStart_toEndOf="@id/block_target_gpa"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="SEMESTER" android:textStyle="bold" android:textSize="11sp"
                        android:textColor="#80B0CC" android:letterSpacing="0.1" />
                    <TextView android:id="@+id/tv_semester_pct" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="62%"
                        android:textStyle="bold" android:textSize="22sp" android:textColor="@color/white"
                        android:layout_marginTop="2dp" />
                    <ProgressBar android:id="@+id/pb_semester"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent" android:layout_height="6dp"
                        android:max="100" android:progress="62"
                        android:progressDrawable="@drawable/progress_teal" android:layout_marginTop="4dp" />
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- QUICK STATS ROW -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:paddingStart="16dp" android:paddingEnd="16dp"
            android:paddingTop="16dp" android:weightSum="3">
            <include android:id="@+id/stat_courses" layout="@layout/item_quick_stat"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginEnd="6dp" />
            <include android:id="@+id/stat_due" layout="@layout/item_quick_stat"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginStart="6dp" android:layout_marginEnd="6dp" />
            <include android:id="@+id/stat_hours" layout="@layout/item_quick_stat"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginStart="6dp" />
        </LinearLayout>

        <!-- ACTIVE COURSES -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="ACTIVE COURSES" android:textSize="12sp" android:textColor="@color/text_secondary"
            android:textAllCaps="true" android:textStyle="bold" android:letterSpacing="0.08"
            android:layout_marginStart="24dp" android:layout_marginTop="24dp" android:layout_marginBottom="8dp" />

        <LinearLayout android:id="@+id/ll_courses" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="vertical"
            android:paddingStart="16dp" android:paddingEnd="16dp" />

        <!-- DUE SOON -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="DUE SOON" android:textSize="12sp" android:textColor="@color/text_secondary"
            android:textAllCaps="true" android:textStyle="bold" android:letterSpacing="0.08"
            android:layout_marginStart="24dp" android:layout_marginTop="16dp" android:layout_marginBottom="8dp" />

        <LinearLayout android:id="@+id/ll_upcoming" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="vertical"
            android:paddingStart="16dp" android:paddingEnd="16dp" android:paddingBottom="24dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
